<%- include('../partials/header') %>

<section class="wallet-header">
    <div>
        <h1 class="h2 mb-1">Buy Pass</h1>
        <p class="text-muted mb-0">Choose a pass and pay using wallet credits.</p>
    </div>
    <a href="/wallet" class="btn btn-outline-primary">Back to Wallet</a>
</section>

<section class="row g-4">
    <% Object.keys(passes).forEach((key) => { %>
        <div class="col-md-6">
            <form action="/wallet/pass" method="POST" class="plan-card h-100">
                <input type="hidden" name="passType" value="<%= key %>">
                <h2 class="h4"><%= passes[key].label %></h2>
                <p class="plan-price"><%= formatCurrency(passes[key].price) %></p>
                <p class="text-muted">
                    <% if (key === 'single_trip') { %>
                        One ride paid from your wallet balance.
                    <% } else { %>
                        A day pass for flexible rides during the day.
                    <% } %>
                </p>
                <button type="submit" class="btn btn-primary w-100" data-confirm-purchase="<%= passes[key].label %>">
                    Buy <%= passes[key].label %>
                </button>
            </form>
        </div>
    <% }) %>
</section>

<%- include('../partials/footer') %>
