<%- include('../partials/header') %>

<section class="content-panel mx-auto">
    <h1 class="h3 mb-3">Top Up Credits</h1>
    <form action="/wallet/topup" method="POST" data-validate-topup>
        <div class="mb-3">
            <label for="amount" class="form-label">Top-up amount</label>
            <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" class="form-control" id="amount" name="amount" min="0.01" step="0.01" placeholder="10.00" required>
            </div>
            <div class="form-text">Amount must be more than 0.</div>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Add Credits</button>
            <a href="/wallet" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</section>

<%- include('../partials/footer') %>
