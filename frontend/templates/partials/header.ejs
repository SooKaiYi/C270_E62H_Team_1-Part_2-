<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Bike Rental</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="/wallet">Bike Rental</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <% if (currentUser) { %>
                        <li class="nav-item"><a class="nav-link" href="/wallet">Wallet</a></li>
                        <li class="nav-item"><a class="nav-link" href="/wallet/topup">Top Up</a></li>
                        <li class="nav-item"><a class="nav-link" href="/wallet/pass">Buy Pass</a></li>
                        <li class="nav-item"><a class="nav-link" href="/wallet/history">History</a></li>
                    <% } %>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <% if (currentUser) { %>
                        <span class="navbar-text text-white"><%= currentUser.name %></span>
                        <form action="/logout" method="POST" class="m-0">
                            <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                        </form>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        <% if (successMessage) { %>
            <div class="alert alert-success"><%= successMessage %></div>
        <% } %>
        <% if (errorMessage) { %>
            <div class="alert alert-danger"><%= errorMessage %></div>
        <% } %>
